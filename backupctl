#!/usr/bin/env bash

LOG="/tmp/backup-progress.log"

notify_silent() {
    if command -v notify-send >/dev/null 2>&1; then
        notify-send "Smart Backup" "$1" 2>/dev/null || true
    fi
}

service_warning() {
    if command -v systemctl >/dev/null 2>&1; then
        if ! systemctl --user is-active --quiet idle-backup.service; then
            echo "Warning: idle-backup.service is not running. Start it with 'systemctl --user start idle-backup.service'."
        fi
    fi
}

case "$1" in
    start)
        touch /tmp/force_backup
        notify_silent "Manual backup started"
        echo "Manual backup started"
        service_warning
        ;;
    stop)
        rm -f /tmp/force_backup
        notify_silent "Manual backup stopped"
        echo "Manual backup stopped"
        service_warning
        ;;
    status)
        if [ -f /tmp/force_backup ]; then
            echo "FORCED MODE"
        else
            echo "AUTO MODE"
        fi
        if command -v systemctl >/dev/null 2>&1; then
            systemctl --user status idle-backup.service --no-pager
        fi
        ;;
    progress)
        if [ ! -f "$LOG" ]; then
            echo "No backup started yet"
            exit 0
        fi

        PROG=$(awk '{for(i=1;i<=NF;i++) if($i ~ /%/) print $i}' "$LOG" | tail -n 1)

        if [[ "$PROG" == *% ]]; then
            echo "Backup Progress: $PROG"
        else
            echo "Calculating..."
        fi
        ;;
    *)
        echo "Usage: backupctl {start|stop|status|progress}"
        ;;
esac
